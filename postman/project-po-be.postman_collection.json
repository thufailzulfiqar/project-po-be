    {
      "name": "PO Documents",
      "item": [
        {
          "name": "List PO Documents",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.documents && json.documents.length && !pm.collectionVariables.get('documentId')) {",
                  "  pm.collectionVariables.set('documentId', json.documents[0].id);",
                  "  if (pm.environment && pm.environment.name) { pm.environment.set('documentId', json.documents[0].id); }",
                  "}"
                ]
              }
            }
          ],
