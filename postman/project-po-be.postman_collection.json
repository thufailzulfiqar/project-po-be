                  "  if (json.job.jobId) setVar('jobId', json.job.jobId);",
                  "  if (json.job.documentId) setVar('documentId', json.job.documentId);",
                  "  console.log('jobId=' + json.job.jobId + ' documentId=' + json.job.documentId + ' status=' + json.job.status);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "description": "Pilih file PO PDF (.pdf) dari komputer Anda",
                  "type": "file",
